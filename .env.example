# ─────────────────────────────────────────────
# Firebase (required)
# Find these in your Firebase Console → Project Settings → General → Your apps
# ─────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Only needed if you use a named Firestore database (not "(default)")
VITE_FIREBASE_FIRESTORE_DATABASE_ID=

# ─────────────────────────────────────────────
# Google Maps (required for map features)
# https://console.cloud.google.com/apis/credentials
# ─────────────────────────────────────────────
VITE_GOOGLE_MAPS_PLATFORM_KEY=

# ─────────────────────────────────────────────
# Email — Resend (preferred)
# https://resend.com/api-keys
# ─────────────────────────────────────────────
RESEND_API_KEY=
RESEND_SENDER_EMAIL=onboarding@resend.dev
RESEND_SENDER_NAME=FarmLink

# ─────────────────────────────────────────────
# Email — Brevo (fallback)
# https://app.brevo.com/settings/keys/api
# ─────────────────────────────────────────────
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=FarmLink

# ─────────────────────────────────────────────
# Admin accounts
# Comma-separated list of emails that should receive admin role on first login.
# NEVER commit real email addresses to source control.
# ─────────────────────────────────────────────
ADMIN_EMAILS=
VITE_ADMIN_EMAILS=
